# ── Spotify ──────────────────────────────────────────────────────────────────
# Create a Spotify app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:8888/callback as a Redirect URI in the app settings.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# The playlist ID where winning tracks are recorded.
# Find it in the Spotify URL: open.spotify.com/playlist/<ID>
SPOTIFY_WINS_PLAYLIST_ID=

# ── Groq ─────────────────────────────────────────────────────────────────────
# Free API key at https://console.groq.com
# Free tier: 100 000 tokens / day (resets midnight UTC).
GROQ_API_KEY=

# ── Last.fm ───────────────────────────────────────────────────────────────────
# Free API key at https://www.last.fm/api/account/create
# Used for similar-artist discovery seeded by past winning tracks.
# Optional — system falls back to Groq agent if not set.
LASTFM_API_KEY=
